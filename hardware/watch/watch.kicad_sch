	(text "BOOTLOADER MODE:\n1. Set rstn pin low for 10ms\n2. while rstn pin is low, set mfio low\n3. After 10s set rstn pin high\n4. After additional 50ms, bootloader mode entered\n\nAPPLICATION MODE:\n1. Set rstn pin low for 10ms\n2. while rstn pin is low, set mfio high\n3. After 10s, set rstn pin high\n4. After additional 50ms, application mode entered"
		(exclude_from_sim no)
		(at 135.89 121.92 0)
		(effects
			(font
				(size 1 1)
			)
			(justify left bottom)
		)
